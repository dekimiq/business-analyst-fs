{
  "name": "@project/bot-interaction",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "migrate": "NODE_OPTIONS='--import tsx/esm' knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "NODE_OPTIONS='--import tsx/esm' knex --knexfile knexfile.ts migrate:rollback",
    "seed": "NODE_OPTIONS='--import tsx/esm' knex --knexfile knexfile.ts seed:run"
  },
  "dependencies": {
    "@project/env": "*",
    "@project/shared": "*",
    "bullmq": "^5.34.0",
    "grammy": "^1.31.0",
    "https-proxy-agent": "^8.0.0",
    "ioredis": "^5.3.2",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "telegramify-markdown": "^1.3.2"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
