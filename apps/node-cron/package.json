{
  "name": "@project/node-cron",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "migrate": "NODE_OPTIONS='--import tsx/esm' knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "NODE_OPTIONS='--import tsx/esm' knex --knexfile knexfile.ts migrate:rollback",
    "seed": "NODE_OPTIONS='--import tsx/esm' knex --knexfile knexfile.ts seed:run"
  },
  "dependencies": {
    "@project/env": "*",
    "bullmq": "^5.34.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "ioredis": "^5.4.1",
    "knex": "^3.1.0",
    "node-cron": "^3.0.3",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
